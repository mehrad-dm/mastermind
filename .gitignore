.DS_Store
*.log
.idea/
.vscode/

# Project-local MasterMind workspace (prefs + generated cycle reports) — created
# when USING the brain in a project; never part of the brain repo itself.
.mastermind/

# Client/project pattern packs — LOCAL ONLY, never publish.
# (~/.mastermind is a symlink to this PUBLIC repo, so local-only requires ignoring.)
engineering/fields/*/*-coding-patterns.md
engineering/fields/*/*-coding-patterns/

# ── Lab: quarantine for raw confidential input. NEVER committed. ──────────────
# Sensitive material lands in lab/ only. Analyse it there; commit only the
# genericized OUTPUT (patterns, not identities). Enforced by .githooks/pre-commit.
# Anchored to the repo root (leading slash) so it does NOT also ignore the
# unrelated skills/lab/ skill directory.
/lab/

# Foglamp scan — commit .foglamp/scan.json (public architecture data, no secrets);
# NEVER commit the lock file (holds the secret editToken). The token lives as the
# GitHub Actions secret FOGLAMP_EDIT_TOKEN, used by .github/workflows/foglamp.yml.
/.foglamp/scan.lock.json
